{
  "name": "ts-monitor-sdk",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./plugins/error": {
      "types": "./dist/esm/plugins/error.d.ts",
      "import": "./dist/esm/plugins/error.js",
      "require": "./dist/cjs/plugins/error.cjs"
    },
    "./plugins/http": {
      "types": "./dist/esm/plugins/http.d.ts",
      "import": "./dist/esm/plugins/http.js",
      "require": "./dist/cjs/plugins/http.cjs"
    },
    "./plugins/behavior": {
      "types": "./dist/esm/plugins/behavior.d.ts",
      "import": "./dist/esm/plugins/behavior.js",
      "require": "./dist/cjs/plugins/behavior.cjs"
    },
    "./plugins/performance": {
      "types": "./dist/esm/plugins/performance.d.ts",
      "import": "./dist/esm/plugins/performance.js",
      "require": "./dist/cjs/plugins/performance.cjs"
    },
    "./plugins/web-vitals": {
      "types": "./dist/esm/plugins/web-vitals.d.ts",
      "import": "./dist/esm/plugins/web-vitals.js",
      "require": "./dist/cjs/plugins/web-vitals.cjs"
    },
    "./plugins/node-error": {
      "types": "./dist/esm/plugins/node-error.d.ts",
      "import": "./dist/esm/plugins/node-error.js",
      "require": "./dist/cjs/plugins/node-error.cjs"
    },
    "./plugins/node-http": {
      "types": "./dist/esm/plugins/node-http.d.ts",
      "import": "./dist/esm/plugins/node-http.js",
      "require": "./dist/cjs/plugins/node-http.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@rslib/core": "^0.19.6",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
